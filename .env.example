# AI Election Navigator — Environment Variables
# Copy this file to .env.local and fill in your values

# Google Gemini API Key (required for AI assistant)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Google Cloud Project ID (for deployment)
# GOOGLE_CLOUD_PROJECT=your-project-id

# Optional: App URL (for canonical links)
# NEXT_PUBLIC_APP_URL=https://your-cloud-run-url.run.app
